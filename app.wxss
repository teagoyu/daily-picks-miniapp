/* Global theme variables */
page {
  --bg: #0d1117;
  --bg-card: #161b22;
  --bg-hover: #21262d;
  --border: #30363d;
  --text: #e6edf3;
  --muted: #8b949e;
  --green: #3fb950;
  --red: #f85149;
  --yellow: #d29922;
  --blue: #58a6ff;
  --purple: #bc8cff;

  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, "PingFang SC", sans-serif;
  font-size: 14px;
}
