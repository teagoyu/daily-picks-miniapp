.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 60rpx;
}

/* ── Hero ────────────────────────────────────── */
.hero {
  padding: 56rpx 32rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.hero-up {
  background: linear-gradient(135deg, #0d2318 0%, #0f2a1c 50%, #0d1117 100%);
  border-bottom: 1rpx solid rgba(63, 185, 80, 0.2);
}

.hero-down {
  background: linear-gradient(135deg, #2a0d0d 0%, #2a1010 50%, #0d1117 100%);
  border-bottom: 1rpx solid rgba(248, 81, 73, 0.2);
}

.hero::after {
  content: '';
  position: absolute;
  right: -60rpx; top: -60rpx;
  width: 300rpx; height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 70%);
}

.hero-inner { position: relative; }

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.hero-badge {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: var(--radius-s);
  padding: 10rpx 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text);
  letter-spacing: 2rpx;
}

.hero-score-ring {
  background: rgba(0,0,0,0.3);
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 50%;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-val {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.ring-label {
  font-size: 18rpx;
  color: var(--muted);
  margin-top: 2rpx;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.hero-sector {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 20rpx;
}

.hero-price-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  margin-top: 8rpx;
}

.hero-price {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
}

.hero-change {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}

/* ── Section Title ────────────────────────────── */
.section-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 3rpx;
  text-transform: uppercase;
  padding: 32rpx 32rpx 16rpx;
}

/* ── Metrics Grid ────────────────────────────── */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 8rpx;
}

.m-box {
  background: var(--bg-card);
  border: 1rpx solid var(--border-l);
  border-radius: var(--radius-m);
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.m-icon { font-size: 36rpx; }
.m-label { font-size: 20rpx; color: var(--muted); text-align: center; }
.m-val { font-size: 32rpx; font-weight: 700; color: var(--text); }
.val-red { color: var(--red); }
.val-green { color: var(--green); }
.val-yellow { color: var(--yellow); font-size: 24rpx; }

/* ── Score Breakdown ─────────────────────────── */
.score-card {
  margin: 0 24rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-l);
  border-radius: var(--radius-l);
  overflow: hidden;
}

.score-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-l);
}

.score-item.last { border-bottom: none; }

.si-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.si-label { font-size: 26rpx; color: var(--text-2); }
.si-pct { font-size: 24rpx; color: var(--muted); font-weight: 600; }

.si-bar-bg {
  height: 6rpx;
  background: var(--bg-hover);
  border-radius: 4rpx;
  overflow: hidden;
}

.si-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--blue), var(--purple));
  border-radius: 4rpx;
}

/* ── Disclaimer ──────────────────────────────── */
.disclaimer {
  font-size: 22rpx;
  color: var(--muted-2);
  text-align: center;
  padding: 32rpx 32rpx 16rpx;
  line-height: 1.6;
}
