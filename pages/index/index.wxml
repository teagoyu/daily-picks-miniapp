<view class="page">

  <!-- ── Header ── -->
  <view class="header">
    <view class="header-top">
      <view>
        <view class="header-eyebrow">DAILY PICKS</view>
        <view class="header-title">每日选股</view>
      </view>
      <view class="date-chip" wx:if="{{date}}">
        <text class="date-dot">●</text>
        <text class="date-text">{{date}}</text>
      </view>
    </view>
    <view class="header-sub" wx:if="{{updatedAt}}">最后更新 {{updatedAt}}</view>
  </view>

  <!-- ── Loading Skeleton ── -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="skel-tabs"></view>
    <view class="skel-card"></view>
    <view class="skel-card short"></view>
    <view class="skel-card"></view>
  </view>

  <!-- ── Error ── -->
  <view wx:elif="{{error}}" class="state-box">
    <text class="state-icon">⚡</text>
    <text class="state-msg">{{error}}</text>
    <view class="retry-btn" bindtap="loadData">重新加载</view>
  </view>

  <!-- ── Content ── -->
  <block wx:else>

    <!-- Market Tabs -->
    <view class="tabs-wrap">
      <view class="tabs">
        <view
          wx:for="{{marketList}}"
          wx:key="*this"
          class="tab {{activeMarket === item ? 'tab-active' : ''}}"
          data-market="{{item}}"
          bindtap="switchMarket"
        >{{markets[item]}}</view>
      </view>
    </view>

    <!-- Picks Section -->
    <view class="section-head">
      <view class="section-dot"></view>
      <text class="section-label">今日精选</text>
      <text class="section-count">TOP {{picks[activeMarket].length}}</text>
    </view>

    <view class="picks-list">
      <view
        wx:for="{{picks[activeMarket]}}"
        wx:key="symbol"
        class="pick-card {{item.change >= 0 ? 'card-up' : 'card-down'}}"
        data-stock="{{item}}"
        bindtap="goDetail"
      >
        <!-- Row 1: rank + symbol + name | price + change -->
        <view class="pc-row1">
          <view class="pc-left">
            <view class="pc-rank">{{index + 1}}</view>
            <view class="pc-sym-wrap">
              <text class="pc-symbol">{{item.symbol}}</text>
              <text class="pc-name">{{item.name}}</text>
            </view>
          </view>
          <view class="pc-right">
            <text class="pc-price">{{item.priceStr}}</text>
            <text class="pc-change" style="color:{{item.changeColor}}">{{item.changeStr}}</text>
          </view>
        </view>

        <!-- Divider -->
        <view class="pc-divider"></view>

        <!-- Row 2: Metrics -->
        <view class="pc-metrics">
          <view class="pc-metric">
            <text class="pm-label">PE</text>
            <text class="pm-val" style="color:{{item.peColor}}">{{item.peStr}}</text>
          </view>
          <view class="pm-sep"></view>
          <view class="pc-metric">
            <text class="pm-label">RSI</text>
            <text class="pm-val">{{item.rsi || '—'}}</text>
          </view>
          <view class="pm-sep"></view>
          <view class="pc-metric">
            <text class="pm-label">换手率</text>
            <text class="pm-val">{{item.turnover_rate ? item.turnover_rate + '%' : '—'}}</text>
          </view>
          <view class="pm-sep"></view>
          <view class="pc-metric">
            <text class="pm-label">均线</text>
            <text class="pm-val pm-ma">{{item.maTag}}</text>
          </view>
          <view class="pm-sep"></view>
          <view class="pc-metric">
            <text class="pm-label">评分</text>
            <text class="pm-val" style="color:{{item.scoreColor}}">{{item.scoreStr}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- All Stocks Toggle -->
    <view class="toggle-row" bindtap="toggleShowAll">
      <view class="toggle-left">
        <text class="toggle-title">全部标的排名</text>
        <text class="toggle-total">共 {{allStocks[activeMarket].length}} 只</text>
      </view>
      <view class="toggle-icon {{showAll ? 'rotate' : ''}}">›</view>
    </view>

    <view wx:if="{{showAll}}" class="all-list">
      <view
        wx:for="{{allStocks[activeMarket]}}"
        wx:key="symbol"
        class="list-row"
        data-stock="{{item}}"
        bindtap="goDetail"
      >
        <view class="lr-rank {{index < 3 ? 'lr-rank-top' : ''}}">{{index + 1}}</view>
        <view class="lr-info">
          <text class="lr-symbol">{{item.symbol}}</text>
          <text class="lr-name">{{item.name}}</text>
        </view>
        <view class="lr-right">
          <text class="lr-change" style="color:{{item.changeColor}}">{{item.changeStr}}</text>
          <text class="lr-score" style="color:{{item.scoreColor}}">{{item.scoreStr}}分</text>
        </view>
        <text class="lr-arrow">›</text>
      </view>
    </view>

  </block>

  <custom-tab-bar />
</view>
